# AgentArmy Environment Configuration
# Copy this file to .env and fill in your API keys

# ===========================================
# LLM Provider API Keys
# ===========================================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================================
# Replit Agents Integration
# ===========================================
# Get your API key from: https://replit.com/@your-username?path=settings
REPLIT_API_KEY=your_replit_api_key_here
REPLIT_WORKSPACE_ID=your_workspace_id_here
REPLIT_AGENT_ID=default
# Session timeout in seconds (default: 120)
REPLIT_TIMEOUT_SECONDS=120
# Auto-cleanup sessions after completion (default: true)
REPLIT_AUTO_CLEANUP=true
# Custom API URL (optional, for enterprise)
# REPLIT_API_URL=https://api.replit.com/v1

# ===========================================
# Voiceflow Conversational AI
# ===========================================
# Get your API key from: https://developer.voiceflow.com/docs/api-keys
VOICEFLOW_API_KEY=your_voiceflow_api_key_here
VOICEFLOW_VERSION_ID=production
# Runtime URL (optional, defaults to Voiceflow's global runtime)
# VOICEFLOW_RUNTIME_URL=https://general-runtime.voiceflow.com
VOICEFLOW_TIMEOUT_SECONDS=30

# ===========================================
# Devin AI (Optional - legacy integration)
# ===========================================
# DEVIN_API_KEY=your_devin_api_key_here

# ===========================================
# Other Services
# ===========================================
MODELSLAB_API_KEY=your_modelslab_api_key_here

# ===========================================
# Application Settings
# ===========================================
PYTHONUNBUFFERED=1

