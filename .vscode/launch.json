{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    "version": "0.2.0", // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "configurations": [
        {
            "name": "Python Debugger: Module",
            "type": "debugpy",
            "request": "launch",
            "module": "enter-your-module-name"
        },
        
        {
   
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Deno: Run",
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}",
            "env": {},
            "runtimeExecutable": "deno",
            "runtimeArgs": [
                "run",
                "--allow-net",
                "--allow-read",
                "--allow-write",
                "--allow-env",
                "--allow-plugin",
                "--allow-ffi",
                "--unstable",
                "--inspect=127.0.0.1:9229",
                "--watch",
                "${file}"
            ],
            "port": 9229,
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}",
            "env": {},
            "runtimeExecutable": "deno",
            "runtimeArgs": [
                "run",
                "--unstable",
                "--unstable-kv",
                "--unstable-cron",
                "--inspect-brk",
                "--allow-read",
                "--allow-write",
                "--allow-net",
                "--allow-env",
                "--allow-run",
                "--allow-ffi",
                "--allow-sys"
            ],
            "attachSimplePort": 9229
        }
    ]
}