# Backend environment variables

# OpenAI API Key (required for real LLM calls)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Anthropic API Key (recommended; Claude Haiku default provider)
ANTHROPIC_API_KEY=

# Anthropic model (default: claude-3-5-haiku-20241022)
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Default provider used when client doesn't specify model
DEFAULT_LLM_PROVIDER=anthropic

# JWT secret for auth (change in production!)
JWT_SECRET=replace-with-strong-secret

# Server port (default: 4000)
PORT=4000
