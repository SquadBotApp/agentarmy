# Orchestration Service Configuration (.env)
# Copy to .env and fill in your keys

# LLM Provider Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk-...
XAI_API_KEY=xai-...
GEMINI_API_KEY=...

# Service Configuration
ORCHESTRATION_PORT=5000
LOG_LEVEL=INFO

# Optional: External services
REDIS_URL=redis://localhost:6379  # For scaling job storage
DATABASE_URL=postgresql://user:pass@localhost:5432/agentarmy  # For persistence

# For production, use secrets vault (HashiCorp Vault, AWS Secrets Manager, etc.)
